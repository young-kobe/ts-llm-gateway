# --- Server ---
PORT=8787

# --- Default routing ---
# Which provider serves a request when the body omits `provider`.
DEFAULT_PROVIDER=bedrock

# --- Amazon Bedrock (primary) ---
# Standard AWS SDK credential env vars are honored by @ai-sdk/amazon-bedrock.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional, for temporary credentials:
# AWS_SESSION_TOKEN=

# --- OpenAI (failover) ---
OPENAI_API_KEY=

# --- Failover ---
# A provider can only be a failover target if a model to use on it is set here,
# because model ids are provider-specific. Leave blank to disable failover to it.
BEDROCK_FALLBACK_MODEL=
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Rate limiting (token bucket, per API key) ---
RATE_LIMIT_CAPACITY=20
RATE_LIMIT_REFILL_PER_SEC=5

# --- Retry + backoff (per provider, before failover) ---
RETRY_MAX_ATTEMPTS=2
RETRY_BASE_DELAY_MS=200
RETRY_MAX_DELAY_MS=2000

# --- Response cache (LRU) ---
CACHE_MAX_ENTRIES=500
# Optional TTL in ms; leave unset for no expiry.
# CACHE_TTL_MS=60000
