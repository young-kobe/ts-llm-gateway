# --- Server ---
PORT=8787

# --- Default routing ---
# Which provider serves a request when the body omits `provider`.
DEFAULT_PROVIDER=bedrock

# --- Amazon Bedrock (primary) ---
# Standard AWS SDK credential env vars are honored by @ai-sdk/amazon-bedrock.
# First enable model access in the Bedrock console (Model access), per region.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional, for temporary credentials:
# AWS_SESSION_TOKEN=
#
# Model ids for the request `model` field. Pick an ACTIVE Anthropic model from the
# Bedrock Model catalog (AWS marks older models Legacy and denies them after 30 days
# idle). Current models need the `us.` cross-region inference-profile prefix; a bare
# id returns a ValidationException asking for an inference profile. Verified working:
#   us.anthropic.claude-haiku-4-5-20251001-v1:0    Claude Haiku 4.5 (cheapest)
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0   Claude Sonnet 4.5

# --- OpenAI (failover) ---
OPENAI_API_KEY=

# --- Failover ---
# A provider can only be a failover target if a model to use on it is set here,
# because model ids are provider-specific. Leave blank to disable failover to it.
BEDROCK_FALLBACK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Auth ---
# Comma-separated allowlist of accepted API keys. When set, callers must present
# one via `x-api-key` or `Authorization: Bearer <key>`, or get 401.
# LEAVE BLANK ONLY FOR LOCAL DEV. An unset value means the endpoint is OPEN.
GATEWAY_API_KEYS=

# --- Request caps (cost / abuse guards) ---
# Hard ceiling on generated tokens; a larger request maxTokens is clamped to this.
MAX_OUTPUT_TOKENS=1024
MAX_MESSAGES=50
MAX_CONTENT_CHARS=8000
MAX_BODY_BYTES=100000
# Optional comma-separated allowlist of model ids; blank = any model permitted.
ALLOWED_MODELS=

# --- Rate limiting (token bucket) ---
# Buckets authorized callers by key, everyone else by client IP.
RATE_LIMIT_CAPACITY=20
RATE_LIMIT_REFILL_PER_SEC=5

# --- Retry + backoff (per provider, before failover) ---
RETRY_MAX_ATTEMPTS=2
RETRY_BASE_DELAY_MS=200
RETRY_MAX_DELAY_MS=2000
# Per-provider-call deadline; a stalled call becomes a fast failure that fails over.
# Keep below the serverless function's max duration.
PROVIDER_TIMEOUT_MS=20000

# --- Circuit breaker (per provider, per instance) ---
# After this many consecutive failures a provider's circuit opens and requests skip
# it (fail fast to failover) until a half-open probe after the cooldown succeeds.
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_COOLDOWN_MS=30000

# --- Response cache (LRU) ---
CACHE_MAX_ENTRIES=500
# Optional TTL in ms; leave unset for no expiry.
# CACHE_TTL_MS=60000

# --- Durable shared store (optional) ---
# When set, the cache, rate limiter, and metrics use Upstash Redis, so they are
# GLOBAL and durable across serverless instances. Unset = in-memory, per-instance.
# The Vercel Marketplace Upstash integration injects these automatically; use the
# read-WRITE token (KV_REST_API_TOKEN), not KV_REST_API_READ_ONLY_TOKEN.
KV_REST_API_URL=
KV_REST_API_TOKEN=
